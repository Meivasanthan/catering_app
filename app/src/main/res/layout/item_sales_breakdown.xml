<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Row 1: Item Name and Amount -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="10">

        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="6"
            android:text="Butter Chicken"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2C3E50" />

        <TextView
            android:id="@+id/tvItemAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="₹12,000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E67E22"
            android:gravity="end" />

    </LinearLayout>

    <!-- Row 2: Progress Bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">

        <!-- Background (Gray) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="#E0E0E0" />

        <!-- Progress (Orange) - This will be adjusted in code -->
        <View
            android:id="@+id/progressBar"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:background="#E67E22" />

    </FrameLayout>

    <!-- Row 3: Percentage (Right aligned) -->
    <TextView
        android:id="@+id/tvPercentage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="100%"
        android:textSize="11sp"
        android:textColor="#7F8C8D"
        android:gravity="end"
        android:layout_marginTop="2dp" />

</LinearLayout>