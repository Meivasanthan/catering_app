<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTooltipDay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍 Saturday"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvTooltipEarnings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💰 Earnings: ₹22,800"
            android:textSize="14sp"
            android:textColor="#E67E22" />

        <TextView
            android:id="@+id/tvTooltipOrders"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📦 Orders: 91"
            android:textSize="14sp"
            android:textColor="#2C3E50" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvTooltipRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⭐ Rating: 4.9"
            android:textSize="14sp"
            android:textColor="#F39C12" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTooltipInsight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🚀 Best day of the week!"
        android:textSize="12sp"
        android:textColor="#7F8C8D"
        android:background="#F0F0F0"
        android:padding="8dp"
        app:cornerRadius="8dp" />

</LinearLayout>