<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row: Order ID + Status + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#ORD-1028"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2C3E50" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟡 New"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="4dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/tvOrderTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30 AM"
                android:textSize="11sp"
                android:textColor="#95A5A6"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Customer Name -->
        <TextView
            android:id="@+id/tvCustomerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Priya Sharma"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:layout_marginTop="12dp" />

        <!-- Items and Price Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvItemCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3 items"
                android:textSize="13sp"
                android:textColor="#7F8C8D" />

            <TextView
                android:id="@+id/tvTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1,200"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E67E22" />

        </LinearLayout>

        <!-- Delivery Address -->
        <TextView
            android:id="@+id/tvDeliveryAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="123 Main Street, New York"
            android:textSize="12sp"
            android:textColor="#95A5A6"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginVertical="12dp" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnView"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="VIEW"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#2C3E50"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="ACCEPT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#27AE60"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecline"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="DECLINE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#E74C3C"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkPreparing"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="PREPARING"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#F39C12"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkOut"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="OUT FOR DELIVERY"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#3498DB"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkDelivered"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="DELIVERED"
                android:textSize="12sp"
                android:textStyle="bold"
                android:backgroundTint="#27AE60"
                android:textColor="#FFFFFF"
                app:cornerRadius="8dp"
                android:layout_marginStart="4dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>