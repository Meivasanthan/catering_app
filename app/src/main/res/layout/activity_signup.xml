<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back Button with arrow icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textSize="16sp"
                android:textColor="#E67E22"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Main Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join Feastly and start your journey"
            android:textSize="14sp"
            android:textColor="#7F8C8D"
            android:layout_marginBottom="32dp" />

        <!-- Role Selection - Customer / Caterer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <RadioGroup
                android:id="@+id/rgRole"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbCustomer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Customer"
                    android:textSize="16sp"
                    android:textColor="#2C3E50"
                    android:buttonTint="#E67E22"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbCaterer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Caterer"
                    android:textSize="16sp"
                    android:textColor="#2C3E50"
                    android:buttonTint="#E67E22" />

            </RadioGroup>

        </LinearLayout>

        <!-- Full Name Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/edittext_bg"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginStart="12dp" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="John Doe"
                android:inputType="textPersonName"
                android:background="@null"
                android:padding="12dp"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Email Address Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/edittext_bg"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="✉️"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginStart="12dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="hello@feastly.com"
                android:inputType="textEmailAddress"
                android:background="@null"
                android:padding="12dp"
                android:textSize="14sp"
                android:autofillHints="email" />

        </LinearLayout>

        <!-- Phone Number Field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/edittext_bg"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginStart="12dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="9876543210"
                android:inputType="phone"
                android:background="@null"
                android:padding="12dp"
                android:textSize="14sp"
                android:maxLength="10"
                android:digits="0123456789" />

        </LinearLayout>

        <!-- Password Field with Show/Hide -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/edittext_bg"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginStart="12dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Must contain letter &amp; number"
                android:inputType="textPassword"
                android:background="@null"
                android:padding="12dp"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvShowPassword"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="👁️"
                android:textSize="20sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp" />

        </LinearLayout>

        <!-- Confirm Password Field with Show/Hide -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/edittext_bg"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginStart="12dp" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Re-enter your password"
                android:inputType="textPassword"
                android:background="@null"
                android:padding="12dp"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvShowConfirmPassword"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="👁️"
                android:textSize="20sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp" />

        </LinearLayout>

        <!-- Create Account Button -->
        <Button
            android:id="@+id/btnCreateAccount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Create Account"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#E67E22"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            android:stateListAnimator="@null" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#7F8C8D"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log In"
                android:textColor="#E67E22"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>